  <assembly fullname="UAssetAPI" preserve="all" required="true" />
  <assembly fullname="Newtonsoft.Json" preserve="all" required="true" />
  <!-- Root the generic collection ctors so Newtonsoft can construct them by reflection
       (including the temporary List<T> it builds for arrays / read-only collections). -->
  <assembly fullname="System.Private.CoreLib">
    <type fullname="System.Collections.Generic.List`1" preserve="all" />
    <type fullname="System.Collections.Generic.Dictionary`2" preserve="all" />
    <type fullname="System.Collections.Generic.LinkedList`1" preserve="all" />
    <type fullname="System.Collections.Generic.LinkedListNode`1" preserve="all" />
  </assembly>
</linker>
